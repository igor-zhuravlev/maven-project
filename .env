# Resource DB
RESOURCE_DB_NAME=resource_db
RESOURCE_DB_USER=postgres
RESOURCE_DB_PASSWORD=postgres

# Song DB
SONG_DB_NAME=song_db
SONG_DB_USER=postgres
SONG_DB_PASSWORD=postgres

# Storage DB
STORAGE_DB_NAME=storage_db
STORAGE_DB_USER=postgres
STORAGE_DB_PASSWORD=postgres

# Spring
RESOURCE_DB_URL=jdbc:postgresql://resource-db:5432/resource_db
SONG_DB_URL=jdbc:postgresql://song-db:5432/song_db
STORAGE_DB_URL=jdbc:postgresql://storage-db:5432/storage_db

CONFIG_SERVER_URL=http://config-server:8888
EUREKA_SERVER_URL=http://eureka-server:8761/eureka

RESOURCE_SERVICE_URL=http://resource-service
SONG_SERVICE_URL=http://song-service
STORAGE_SERVICE_URL=http://storage-service

GATEWAY_SERVER_HOSTNAME=gateway-server
RABBITMQ_HOSTNAME=rabbitmq

CONFIG_REPO_URI=https://github.com/igor-zhuravlev/ms-project-configs
CONFIG_REPO_BRANCH=master

IDP_ISSUER_URI=http://localhost:8088/realms/ms-project
IDP_JWK_SET_URI=http://keycloak:8080/realms/ms-project/protocol/openid-connect/certs

# Localstack
LOCALSTACK_ENDPOINT=http://localstack:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Elasticsearch
ELASTICSEARCH_ENDPOINT=http://elasticsearch:9200

# Logs
RESOURCE_SERVICE_LOG_FILE=/logs/resource-service.log
SONG_SERVICE_LOG_FILE=/logs/song-service.log
STORAGE_SERVICE_LOG_FILE=/logs/storage-service.log
RESOURCE_PROCESSOR_LOG_FILE=/logs/resource-processor.log
CONFIG_SERVER_LOG_FILE=/logs/config-server.log
EUREKA_SERVER_LOG_FILE=/logs/eureka-server.log
GATEWAY_SERVER_LOG_FILE=/logs/gateway-server.log

# Prometheus
PROMETHEUS_ENDPOINT=http://prometheus:9090

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Keycloak
KC_BOOTSTRAP_ADMIN_USERNAME=admin
KC_BOOTSTRAP_ADMIN_PASSWORD=admin